{
  "name": "@cdoprof/api-contracts",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "dependencies": {
    "@cdoprof/shared-types": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "contracts:lint": "node scripts/lint-contracts.mjs",
    "contracts:generate": "node scripts/generate.mjs",
    "contracts:check-generated": "node scripts/check-generated.mjs"
  }
}
