{
  "name": "@cdoprof/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "pnpm --filter @cdoprof/shared-types build && pnpm --filter @cdoprof/api-contracts build && tsc -p tsconfig.json --noEmit",
    "test": "vitest run --no-file-parallelism"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@cdoprof/api-contracts": "workspace:*",
    "@nestjs/common": "^11.0.11",
    "@nestjs/core": "^11.0.11",
    "@nestjs/event-emitter": "^3.0.0",
    "@nestjs/throttler": "^6.4.0",
    "amqplib": "^1.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "pg": "^8.20.0",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.0",
    "@types/amqplib": "^0.10.8",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0"
  }
}
