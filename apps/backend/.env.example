NODE_ENV=development
DEPLOYMENT_PROFILE=dev
RELEASE_VERSION=dev-local
BACKEND_PORT=3001
API_PREFIX=/api/v1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cdoprof
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://guest:guest@localhost:5672
# Секрет для вызова worker → POST /api/v1/internal/worker/* (массовые зачисления в очереди)
WORKER_CALLBACK_SECRET=change-me-worker-callback-local
JOB_EXCHANGE=jobs.topic
JOB_ROUTING_BULK_ENROLLMENT=lms.bulk_enrollment
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=cdoprof-dev
SECRETS_PROVIDER=env
AUTH_JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production
AUTH_JWT_SECRET_KEY_REF=auth.jwt
AUTH_JWT_SECRET_VERSION=latest
SESSION_SECRET_KEY_REF=session.cookie
SESSION_SECRET_VERSION=latest
SECRET_ROTATION_MAX_AGE_DAYS=30
# For SECRETS_PROVIDER=vault
# VAULT_ADDR=https://vault.internal
# VAULT_TOKEN=replace-me
# VAULT_MOUNT=secret
# Mirrored secret values for local runs/testing:
# VAULT_SECRET_AUTH_JWT_V1=...
# VAULT_SECRET_SESSION_COOKIE_V1=...
# For SECRETS_PROVIDER=kms
# KMS_ENDPOINT=https://kms.internal
# KMS_KEY_RING=backend
# KMS_SECRET_AUTH_JWT_V1=...
# KMS_SECRET_SESSION_COOKIE_V1=...
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
DB_MIGRATIONS_ENABLED=true
DB_MIGRATIONS_DIR=migrations
READINESS_QUEUE_BACKLOG_THRESHOLD=1000
READINESS_QUEUE_LAG_SECONDS_THRESHOLD=300
READINESS_OUTBOX_BACKLOG_THRESHOLD=500
# MVP domain: memory (in-process map per tenant) | postgres (learning.mvp_runtime_documents)
MVP_PERSISTENCE_DRIVER=memory
DOCUMENTS_PERSISTENCE_DRIVER=memory
ALLOW_IN_MEMORY_STATE=true
CORS_ORIGIN=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3001
REALTIME_PUBLIC_URL=http://localhost:3002
REALTIME_PUBLISH_KEY=change-me-realtime-key
# В production обязателен (см. backend env schema)
INTEGRATION_WEBHOOK_SECRET=dev-webhook-secret-min-10
OUTBOX_PUBLISHER_ENABLED=true
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_RETRIES=10
