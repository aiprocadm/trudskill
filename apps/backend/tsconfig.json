{
  "extends": "../../tooling/typescript/tsconfig.app.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "exactOptionalPropertyTypes": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "src/**/*.test.ts", "src/**/*integration.test.ts", "src/**/*.e2e.test.ts"],
  "references": [
    { "path": "../../packages/shared-types" },
    { "path": "../../packages/api-contracts" }
  ]
}
