NODE_ENV=development
RELEASE_VERSION=dev-local
WORKER_CONCURRENCY=5
WORKER_PREFETCH=20
WORKER_MAX_RETRIES=10
WORKER_BACKOFF_BASE_MS=1000
WORKER_BACKOFF_MAX_MS=300000
WORKER_CONSUMER_NAME=worker.document-integration-notification
DOCUMENT_GENERATION_QUEUE=documents.generation
WORKER_EXCHANGE=jobs.topic
WORKER_RETRY_EXCHANGE=jobs.retry.topic
WORKER_DLX_EXCHANGE=jobs.dlx.topic
WORKER_DLQ_QUEUE=jobs.dead-letter
RABBITMQ_URL=amqp://guest:guest@localhost:5672
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cdoprof
REDIS_URL=redis://localhost:6379
WORKER_INTERNAL_URL=http://localhost:3010
BACKEND_PUBLIC_URL=http://localhost:3001
# Должен совпадать с WORKER_CALLBACK_SECRET у backend
WORKER_CALLBACK_TOKEN=change-me-worker-callback-local
DOCUMENTS_STORAGE_BUCKET=cdoprof-dev
