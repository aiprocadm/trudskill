# ==========================================================
# Global runtime mode
# ==========================================================
NODE_ENV=development

# ==========================================================
# Infrastructure services (shared)
# ==========================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cdoprof
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://guest:guest@localhost:5672
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=cdoprof-dev

# ==========================================================
# Shared auth/session/cors baseline
# ==========================================================
AUTH_JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3000

# ==========================================================
# Service ports
# ==========================================================
FRONTEND_PORT=3000
BACKEND_PORT=3001
REALTIME_PORT=3002

# ==========================================================
# Internal service URLs
# ==========================================================
BACKEND_PUBLIC_URL=http://localhost:3001
REALTIME_PUBLIC_URL=http://localhost:3002
WORKER_INTERNAL_URL=http://localhost:3010

# ==========================================================
# Frontend public variables (must start with NEXT_PUBLIC_)
# ==========================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_REALTIME_URL=ws://localhost:3002

# ==========================================================
# Worker app specific
# ==========================================================
WORKER_CONCURRENCY=5
