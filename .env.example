NODE_ENV=development
RELEASE_VERSION=dev-local

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cdoprof
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://guest:guest@localhost:5672
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=cdoprof-dev

AUTH_JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3000

FRONTEND_PORT=3000
BACKEND_PORT=3001
REALTIME_PORT=3002

BACKEND_PUBLIC_URL=http://localhost:3001
REALTIME_PUBLIC_URL=http://localhost:3002
WORKER_INTERNAL_URL=http://localhost:3010

# Должен совпадать с API_PREFIX бэкенда (по умолчанию /api/v1), иначе фронт бьёт не в те маршруты
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_REALTIME_URL=ws://localhost:3002

WORKER_CONCURRENCY=5
DOCUMENT_GENERATION_QUEUE=documents.generation
DOCUMENTS_STORAGE_BUCKET=cdoprof-dev
REALTIME_PUBLISH_KEY=change-me-realtime-key
# Обязателен при NODE_ENV=production (проверка подписи вебхуков интеграций)
INTEGRATION_WEBHOOK_SECRET=dev-webhook-secret-min-10
DB_MIGRATIONS_ENABLED=true
DB_MIGRATIONS_DIR=migrations
