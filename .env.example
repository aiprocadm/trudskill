NODE_ENV=development
RELEASE_VERSION=dev-local

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/cdoprof
REDIS_URL=redis://127.0.0.1:6379
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=cdoprof-dev

# Antivirus scan gate (V1.1). When false, NoopAntivirusScanner marks files clean (dev/pilot).
# Flip to true ONLY when a clamd instance is reachable at CLAMAV_HOST:CLAMAV_PORT (spec §9).
ANTIVIRUS_ENABLED=false
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# Email notifications (Phase 5). When false, NoopMailer records deliveries as skipped (dev/pilot).
# Flip to true ONLY when SMTP_* point at a reachable mail server.
NOTIFICATIONS_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@cdoprof.local

AUTH_JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production
AUTH_PROVIDER=legacy
SUPERTOKENS_CORE_URI=http://127.0.0.1:3567
SUPERTOKENS_API_KEY=change-me-supertokens-api-key
SUPERTOKENS_APP_NAME=cdoprof
SUPERTOKENS_API_DOMAIN=http://localhost:3001
SUPERTOKENS_WEBSITE_DOMAIN=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3000

FRONTEND_PORT=3000
BACKEND_PORT=3001
REALTIME_PORT=3002

BACKEND_PUBLIC_URL=http://localhost:3001
REALTIME_PUBLIC_URL=http://localhost:3002
WORKER_INTERNAL_URL=http://localhost:3010

# Должен совпадать с API_PREFIX бэкенда (по умолчанию /api/v1), иначе фронт бьёт не в те маршруты
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_REALTIME_URL=ws://localhost:3002

WORKER_CONCURRENCY=5
DOCUMENT_GENERATION_QUEUE=documents.generation
DOCUMENTS_STORAGE_BUCKET=cdoprof-dev
REALTIME_PUBLISH_KEY=change-me-realtime-key
REALTIME_STREAM_MAXLEN=5000
REALTIME_STREAM_TTL_SECONDS=86400
REALTIME_STREAM_READ_BATCH=200
REALTIME_DIAGNOSTICS_MAX_ITEMS=1000
REALTIME_DIAGNOSTICS_TTL_SECONDS=604800
# Обязателен при NODE_ENV=production (проверка подписи вебхуков интеграций)
INTEGRATION_WEBHOOK_SECRET=dev-webhook-secret-min-10
DB_MIGRATIONS_ENABLED=true
DB_MIGRATIONS_DIR=migrations
